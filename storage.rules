rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function activeUser() {
      return signedIn() && userDoc().data.status == 'active';
    }

    function isAdmin() {
      return activeUser() && (request.auth.token.role == 'admin' || userDoc().data.role == 'admin');
    }

    match /projects/{projectId}/floorplans/{userId}/{allPaths=**} {
      allow read: if activeUser() && (request.auth.uid == userId || isAdmin());
      allow write: if activeUser() && request.auth.uid == userId && request.resource.size < 15 * 1024 * 1024 && request.resource.contentType.matches('image/.*|application/pdf');
    }

    match /projects/{projectId}/site-observations/{userId}/{allPaths=**} {
      allow read: if activeUser() && (request.auth.uid == userId || isAdmin());
      allow write: if activeUser() && request.auth.uid == userId && request.resource.size < 15 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}
