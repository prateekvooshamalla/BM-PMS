{
  "name": "bharat-makaan-v2-9-functions",
  "private": true,
  "description": "Cloud Functions for Firebase",
  "type": "module",
  "engines": {
    "node": "20"
  },
  "main": "src/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint \"**/*.js\" --max-warnings=0",
    "serve": "firebase emulators:start --only functions",
