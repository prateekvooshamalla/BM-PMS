VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
VITE_FIREBASE_FUNCTIONS_REGION=us-central1
VITE_FIREBASE_APPCHECK_SITE_KEY=optional_recaptcha_v3_site_key

# Cloud Functions environment
# Configure these in Firebase Functions runtime or local emulator env.
# OPENAI_API_KEY should never be exposed to the frontend.
# Optional model overrides:
# OPENAI_MODEL_ANALYSIS=gpt-5-mini
# OPENAI_MODEL_MARKET=gpt-5
# OPENAI_MODEL_QUOTES=gpt-5-mini
# OPENAI_MODEL_SITE=gpt-5-mini
# OPENAI_MODEL_FLOORPLAN=gpt-5-mini
# ENFORCE_APP_CHECK=true
