rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function activeUser() {
      return signedIn() && userDoc().exists() && userDoc().data.status == 'active';
    }

    function isAdmin() {
      return activeUser() && (request.auth.token.role == 'admin' || userDoc().data.role == 'admin');
    }

    function isProjectMember(projectId) {
      return activeUser() && (
        isAdmin() ||
        get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid ||
        request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds
      );
    }

    match /users/{userId} {
      allow read: if activeUser() && (request.auth.uid == userId || isAdmin());
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if activeUser() && (
        request.auth.uid == userId &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.status == resource.data.status
      ) || isAdmin();
      allow delete: if false;
    }

    match /projects/{projectId} {
      allow create: if activeUser() && request.resource.data.ownerId == request.auth.uid && request.auth.uid in request.resource.data.memberIds;
      allow read, update: if isProjectMember(projectId);
      allow delete: if isAdmin() || (activeUser() && resource.data.ownerId == request.auth.uid);

      match /tasks/{taskId} {
        allow read: if isProjectMember(projectId);
        allow create, update: if isProjectMember(projectId);
        allow delete: if isAdmin();
      }

      match /reports/{reportId} {
        allow read, create: if isProjectMember(projectId);
        allow update, delete: if isAdmin();
      }

      match /quotes/{quoteId} {
        allow read, create, update: if isProjectMember(projectId);
        allow delete: if isAdmin();
      }

      match /siteObservations/{observationId} {
        allow read, create, update: if isProjectMember(projectId);
        allow delete: if isAdmin();
      }

      match /floorPlanAnalyses/{analysisId} {
        allow read, create: if isProjectMember(projectId);
        allow update, delete: if isAdmin();
      }
    }

    match /masters/{masterType}/rows/{rowId} {
      allow read: if activeUser();
      allow write: if isAdmin();
    }

    match /marketSnapshots/{cityId} {
      allow read: if activeUser();
      allow write: if isAdmin();
    }

    match /verifiedPrices/{cityId}/rows/{rowId} {
      allow read: if activeUser();
      allow write: if isAdmin();
    }
  }
}
